# Server config
PORT=3001
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3001

# Label shown in the dashboard header
ENV_LABEL=local

# ── MCP inbound authentication (recommended for any public URL) ────────
# Leave disabled only for local development.
# MCP_AUTH_ENABLED=false
# MCP_AUTH_TYPE=bearer
# MCP_AUTH_TOKEN=replace-with-a-long-random-secret
#
# Or use custom header mode:
# MCP_AUTH_ENABLED=true
# MCP_AUTH_TYPE=header
# MCP_AUTH_HEADER_NAME=X-MCP-API-Key
# MCP_AUTH_HEADER_VALUE=replace-with-a-long-random-secret

# ── Leaping AI (add later when connecting real functions) ──────────────
# LEAPING_API_KEY=your-key-here
# LEAPING_API_BASE=https://api.leaping.ai/v1

# ── Marie CRM proxy (required for pmb_safe_get_customer_by_* tools) ───
# Same backend as Leaping native HTTP functions (PHP GET endpoints).
# LEAPING_FUNC_BASE=https://pflegemittelbox.de/api_leapingai
# LEAPING_FUNC_TOKEN=your-marie-api-token
#
# Optional overrides (defaults match production Leaping natives):
# LEAPING_FUNC_VNR_ENDPOINT=kunde_vnr.php
# LEAPING_FUNC_PLZ_GEB_ENDPOINT=kunde_plzb.php
# LEAPING_FUNC_VNR_PARAM=insurance_number
# LEAPING_FUNC_PLZ_PARAM=plz
# LEAPING_FUNC_HNR_PARAM=hnr
# LEAPING_FUNC_BDAY_PARAM=bday
#
# LEAPING_FUNC_API_KEY is an alias for LEAPING_FUNC_TOKEN.

# ── Test-only post-call alert emails (optional) ────────────────────────
# ALERT_EMAIL_PROVIDER=gmail
# RESEND_API_KEY=re_xxxxxxxxx
# ALERT_EMAIL_FROM=Pflegemittelbox Alerts <alerts@yourdomain.com>
# ALERT_EMAIL_TO=you@example.com
# ALERT_EMAIL_SUBJECT_PREFIX=[Pflegemittelbox Test]
# GMAIL_SMTP_USER=yourgmail@gmail.com
# GMAIL_SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
# ALERT_EMAIL_LLM_ENABLED=false
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Optional background Leaping post-call monitor ──────────────────────
# Runs outside the Leaping workflow graph and checks recent finished calls.
# POST_CALL_MONITOR_ENABLED=false
# POST_CALL_MONITOR_INTERVAL_SECONDS=60
# POST_CALL_MONITOR_LOOKBACK_MINUTES=15
# POST_CALL_MONITOR_FETCH_LIMIT=100
# LEAPING_API_BASE_URL=https://api.leaping.ai/v1
# LEAPING_API_USERNAME=service-user@example.com
# LEAPING_API_PASSWORD=your-password
# LEAPING_API_CLIENT_ID=
# LEAPING_API_CLIENT_SECRET=
# LEAPING_AGENT_ID=your-agent-id
