NODE_ENV=production
ENV_LABEL=company
PORT=3000
PUBLIC_BASE_URL=https://leapingai-api.pflegemittelbox.de

# Required MCP authentication for any public production deployment.
# Option A: Bearer token
MCP_AUTH_ENABLED=true
MCP_AUTH_TYPE=bearer
MCP_AUTH_TOKEN=replace-with-a-long-random-secret

# Option B: Custom header (use this instead of the bearer values above)
# MCP_AUTH_ENABLED=true
# MCP_AUTH_TYPE=header
# MCP_AUTH_HEADER_NAME=X-MCP-API-Key
# MCP_AUTH_HEADER_VALUE=replace-with-a-long-random-secret

# Optional post-call monitoring and alerting can be enabled later.
# Leave these unset for the initial company-server deployment unless needed.
# POST_CALL_MONITOR_ENABLED=false
# ALERT_EMAIL_PROVIDER=gmail
# ALERT_EMAIL_FROM=Pflegemittelbox Alerts <alerts@pflegemittelbox.de>
# ALERT_EMAIL_TO=ops@pflegemittelbox.de
# GMAIL_SMTP_USER=your-account@gmail.com
# GMAIL_SMTP_APP_PASSWORD=your-app-password
# ALERT_EMAIL_LLM_ENABLED=false
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# LEAPING_API_BASE_URL=https://api.leaping.ai/v1
# LEAPING_API_USERNAME=
# LEAPING_API_PASSWORD=
# LEAPING_AGENT_ID=
